  ;; Pin 9 = GND, Pin 10 = GPIO15, Pin 11 = GPIO17, Pin 12 = GPIO18/I2S_BCLK
  ;; Pin 17 = 3V3, Pin 19 = GPIO10/SPI_MOSI, Pin 21 = GPIO9, Pin 23 = GPIO11/SPI_SCLK
  ;; Pin 24 = GPIO8/SPI_CE0, Pin 25 = GND, Pin 29 = GPIO5, Pin 31 = GPIO6
  ;; Pin 32 = GPIO12/PWM0, Pin 33 = GPIO13, Pin 35 = GPIO19/I2S_LRCK, Pin 36 = GPIO16
