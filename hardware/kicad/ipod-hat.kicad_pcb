(kicad_pcb
  (version 20240108)
  (generator "pcbnew")
  (generator_version "8.0")
  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user "B.Mask")
    (39 "F.Mask" user "F.Mask")
    (40 "Dwgs.User" user "User.Drawings")
    (41 "Cmts.User" user "User.Comments")
    (42 "B.CrtYd" user "B.Courtyard")
    (43 "F.CrtYd" user "F.Courtyard")
    (44 "B.Fab" user "B.Fab")
    (45 "F.Fab" user "F.Fab")
    (46 "User.1" user)
    (47 "User.2" user)
  )
  (setup
    (pad_to_mask_clearance 0)
    (allow_soldermask_bridges_in_footprints no)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros no)
      (usegerberextensions no)
      (usegerberattributes yes)
      (usegerberadvancedattributes yes)
      (creategerberjobfile yes)
      (dashed_line_dash_ratio 12.000000)
      (dashed_line_gap_ratio 3.000000)
      (svgprecision 4)
      (plotframeref no)
      (viasonmask no)
      (mode 1)
      (useauxorigin no)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15.000000)
      (pdf_front_fp_property_popups yes)
      (pdf_back_fp_property_popups yes)
      (dxfpolygonmode yes)
      (dxfimperialunits yes)
      (dxfusepcbnewfont yes)
      (psnegative no)
      (psa4output no)
      (plotreference yes)
      (plotvalue yes)
      (plotfptext yes)
      (plotinvisibletext no)
      (sketchpadsonfab no)
      (subtractmaskfromsilk no)
      (outputformat 1)
      (mirror no)
      (drillshape 1)
      (scaleselection 1)
      (outputdirectory "")
    )
  )

  ;; Board outline - RPi HAT form factor: 65mm x 56.5mm
  ;; With rounded corners (3mm radius)
  (gr_rect (start 0 0) (end 65 56.5)
    (stroke (width 0.15) (type default))
    (fill none)
    (layer "Edge.Cuts")
    (uuid "d0000001-0001-4000-8000-000000000001")
  )

  ;; RPi mounting holes - standard HAT positions
  ;; Hole spacing: 58mm x 23mm, offset 3.5mm from edges
  (footprint "MountingHole:MountingHole_2.7mm_M2.5" (at 3.5 3.5) (layer "F.Cu")
    (uuid "d0000002-0001-4000-8000-000000000001")
    (property "Reference" "H1" (at 0 -3 0) (layer "F.SilkS") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "MountingHole" (at 0 3 0) (layer "F.Fab") (effects (font (size 1 1) (thickness 0.15))))
    (pad "" thru_hole circle (at 0 0) (size 5.5 5.5) (drill 2.7) (layers "*.Cu" "*.Mask"))
  )
  (footprint "MountingHole:MountingHole_2.7mm_M2.5" (at 61.5 3.5) (layer "F.Cu")
    (uuid "d0000002-0002-4000-8000-000000000001")
    (property "Reference" "H2" (at 0 -3 0) (layer "F.SilkS") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "MountingHole" (at 0 3 0) (layer "F.Fab") (effects (font (size 1 1) (thickness 0.15))))
    (pad "" thru_hole circle (at 0 0) (size 5.5 5.5) (drill 2.7) (layers "*.Cu" "*.Mask"))
  )
  (footprint "MountingHole:MountingHole_2.7mm_M2.5" (at 3.5 52.5) (layer "F.Cu")
    (uuid "d0000002-0003-4000-8000-000000000001")
    (property "Reference" "H3" (at 0 -3 0) (layer "F.SilkS") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "MountingHole" (at 0 3 0) (layer "F.Fab") (effects (font (size 1 1) (thickness 0.15))))
    (pad "" thru_hole circle (at 0 0) (size 5.5 5.5) (drill 2.7) (layers "*.Cu" "*.Mask"))
  )
  (footprint "MountingHole:MountingHole_2.7mm_M2.5" (at 61.5 52.5) (layer "F.Cu")
    (uuid "d0000002-0004-4000-8000-000000000001")
    (property "Reference" "H4" (at 0 -3 0) (layer "F.SilkS") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "MountingHole" (at 0 3 0) (layer "F.Fab") (effects (font (size 1 1) (thickness 0.15))))
    (pad "" thru_hole circle (at 0 0) (size 5.5 5.5) (drill 2.7) (layers "*.Cu" "*.Mask"))
  )

  ;; Silkscreen labels for component placement zones
  (gr_text "iPod Player HAT v0.1" (at 32.5 54) (layer "F.SilkS")
    (effects (font (size 1.5 1.5) (thickness 0.15)))
    (uuid "d0000003-0001-4000-8000-000000000001"))

  (gr_text "GPIO Header" (at 11 28) (layer "F.SilkS")
    (effects (font (size 1 1) (thickness 0.15)))
    (uuid "d0000003-0002-4000-8000-000000000001"))

  (gr_text "PCM5102A" (at 40 15) (layer "F.SilkS")
    (effects (font (size 1 1) (thickness 0.15)))
    (uuid "d0000003-0003-4000-8000-000000000001"))

  (gr_text "3.5mm" (at 60 15) (layer "F.SilkS")
    (effects (font (size 1 1) (thickness 0.15)))
    (uuid "d0000003-0004-4000-8000-000000000001"))

  (gr_text "USB-C" (at 55 45) (layer "F.SilkS")
    (effects (font (size 1 1) (thickness 0.15)))
    (uuid "d0000003-0005-4000-8000-000000000001"))

  (gr_text "TP4056" (at 35 40) (layer "F.SilkS")
    (effects (font (size 1 1) (thickness 0.15)))
    (uuid "d0000003-0006-4000-8000-000000000001"))

  (gr_text "MT3608" (at 35 50) (layer "F.SilkS")
    (effects (font (size 1 1) (thickness 0.15)))
    (uuid "d0000003-0007-4000-8000-000000000001"))

  (gr_text "BATT" (at 50 40) (layer "F.SilkS")
    (effects (font (size 1 1) (thickness 0.15)))
    (uuid "d0000003-0008-4000-8000-000000000001"))

  ;; Ground plane zone (back copper)
  (zone (net 0) (net_name "GND") (layer "B.Cu") (uuid "d0000004-0001-4000-8000-000000000001")
    (hatch edge 0.5)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (filled_areas_thickness no)
    (fill yes (thermal_gap 0.5) (thermal_bridge_width 0.5))
    (polygon (pts
      (xy 0.5 0.5) (xy 64.5 0.5) (xy 64.5 56) (xy 0.5 56)
    ))
  )

  ;; Ground plane zone (front copper)
  (zone (net 0) (net_name "GND") (layer "F.Cu") (uuid "d0000004-0002-4000-8000-000000000001")
    (hatch edge 0.5)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (filled_areas_thickness no)
    (fill yes (thermal_gap 0.5) (thermal_bridge_width 0.5))
    (polygon (pts
      (xy 0.5 0.5) (xy 64.5 0.5) (xy 64.5 56) (xy 0.5 56)
    ))
  )
)
